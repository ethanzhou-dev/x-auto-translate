{
  "manifest_version": 3,
  "name": "X Auto Translator",
  "version": "1.0.0",
  "description": "在 X 中自动将外语推文和评论翻译为中文。",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "翻译设置"
  },
  "content_scripts": [
    {
      "matches": ["*://twitter.com/*", "*://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
